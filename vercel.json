{
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "src/**"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/live/:channel",
      "destination": "/api/live/:channel"
    },
    {
      "source": "/live/:channel",
      "has": [{ "type": "query", "key": "format", "value": "json" }],
      "destination": "/api/live/:channel?format=json"
    }
  ]
}
